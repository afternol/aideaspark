generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  bio             String?
  interests       String?   // JSON array of category groups
  onboarded       Boolean   @default(false)
  profilePublic   Boolean   @default(true)
  accounts        Account[]
  sessions        Session[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Idea {
  id               String   @id
  slug             String   @unique @default("")
  number           Int      @unique
  serviceName      String
  concept          String
  target           String
  problem          String
  product          String
  revenueModel     String
  competitors      String
  competitiveEdge  String
  tags             String   // JSON array as string
  category         String
  targetIndustry   String
  targetCustomer   String    @default("")
  investmentScale  String
  difficulty       String
  scores           String   // JSON object as string
  scoreComments    String   // JSON object as string
  trendKeywords    String   // JSON array as string
  oneLiner         String
  publishedAt      String
  views            Int      @default(0)
  bookmarks        Int      @default(0)
  inspirationSource String?

  reactions        Reaction[]
  comments         Comment[]
  declarations     Declaration[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Reaction {
  id        String   @id @default(cuid())
  ideaId    String
  sessionId String
  type      String
  createdAt DateTime @default(now())

  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([ideaId, sessionId, type])
}

model Comment {
  id        String    @id @default(cuid())
  ideaId    String
  sessionId String
  nickname  String    @default("匿名")
  body      String
  parentId  String?
  createdAt DateTime  @default(now())

  idea      Idea      @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentThread", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentThread")
}

model Declaration {
  id        String   @id @default(cuid())
  ideaId    String
  sessionId String
  message   String?
  createdAt DateTime @default(now())

  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([ideaId, sessionId])
}

model Collection {
  id        String   @id @default(cuid())
  sessionId String
  name      String
  createdAt DateTime @default(now())
  items     CollectionItem[]

  @@unique([sessionId, name])
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  ideaId       String
  addedAt      DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, ideaId])
}

model Note {
  id        String   @id @default(cuid())
  ideaId    String
  sessionId String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ideaId, sessionId])
}

model ViewHistory {
  id        String   @id @default(cuid())
  userId    String
  ideaId    String
  viewedAt  DateTime @default(now())

  @@unique([userId, ideaId])
  @@index([userId, viewedAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // comment_reply, idea_comment, collection_update
  message   String
  linkUrl   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model CustomIdea {
  id            String   @id @default(cuid())
  userId        String
  baseIdeaId    String
  conditions    String   // JSON: budget, teamSize, skills, timeline
  result        String   // JSON: customized idea data
  createdAt     DateTime @default(now())

  @@index([userId])
}

model BusinessPlan {
  id            String   @id @default(cuid())
  userId        String
  ideaId        String?       // original idea
  customIdeaId  String?       // or customized idea
  content       String   // JSON: full plan content
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model TrendCache {
  id            String   @id
  keyword       String   @unique
  category      String
  description   String
  relatedIdeaIds String  // JSON array
  gtInterest    Float    @default(0)
  gtMomentum    Float    @default(0)
  platformScore Float    @default(0)
  totalScore    Float    @default(0)
  momentum      String   @default("stable") // rising | stable | declining
  fetchedAt     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
