generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  bio             String?
  interests       String?   // JSON array of category groups
  onboarded       Boolean   @default(false)
  profilePublic   Boolean   @default(true)
  accounts        Account[]
  sessions        Session[]
  comments        Comment[]
  reactions       Reaction[]
  declarations    Declaration[]
  viewHistories   ViewHistory[]
  notifications   Notification[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Idea {
  id               String   @id
  slug             String   @unique @default("")
  number           Int      @unique
  serviceName      String
  concept          String
  target           String
  problem          String
  product          String
  revenueModel     String
  competitors      String
  competitiveEdge  String
  tags             Json     // array
  category         String
  targetIndustry   String
  targetCustomer   String    @default("")
  investmentScale  String
  difficulty       String
  scores           Json     // object
  scoreComments    Json     // object
  trendKeywords    Json     // array
  oneLiner         String
  publishedAt      String
  views            Int      @default(0)
  bookmarks        Int      @default(0)
  inspirationSource  String?
  patterns           Json     @default("[]") // array of pattern IDs e.g. ["A-1", "B-3"]
  whyNow             String?  // なぜ今このビジネスか（タイミング根拠）
  noveltyNote        String?  // 何が新しいのか
  strengthNote       String?  // 何が良いのか（強み・優位性）
  patternRationale   String?  // パターン複合の説明（なぜこの組み合わせか）

  reactions        Reaction[]
  comments         Comment[]
  declarations     Declaration[]
  ratings          IdeaRating[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Reaction {
  id        String   @id @default(cuid())
  ideaId    String
  sessionId String
  userId    String?  // authenticated user (null for anonymous)
  type      String
  createdAt DateTime @default(now())

  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([ideaId, sessionId, type])
}

model Comment {
  id        String    @id @default(cuid())
  ideaId    String
  sessionId String
  userId    String?   // authenticated user (null for anonymous)
  nickname  String    @default("匿名")
  body      String
  parentId  String?
  deletedAt DateTime? // soft delete
  createdAt DateTime  @default(now())

  idea      Idea      @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  parent    Comment?  @relation("CommentThread", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentThread")
}

model Declaration {
  id        String   @id @default(cuid())
  ideaId    String
  sessionId String
  userId    String?  // authenticated user (null for anonymous)
  message   String?
  createdAt DateTime @default(now())

  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([ideaId, sessionId])
}

model Collection {
  id        String   @id @default(cuid())
  sessionId String
  name      String
  createdAt DateTime @default(now())
  items     CollectionItem[]

  @@unique([sessionId, name])
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  ideaId       String
  addedAt      DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, ideaId])
}

model Note {
  id        String   @id @default(cuid())
  ideaId    String
  sessionId String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ideaId, sessionId])
}

model ViewHistory {
  id        String   @id @default(cuid())
  userId    String
  ideaId    String
  viewedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ideaId])
  @@index([userId, viewedAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // comment_reply, idea_comment, collection_update
  message   String
  linkUrl   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model CustomIdea {
  id            String   @id @default(cuid())
  userId        String   // stores sessionId or userId
  baseIdeaId    String
  conditions    Json     // budget, teamSize, skills, timeline
  result        Json     // customized idea data
  createdAt     DateTime @default(now())

  @@index([userId])
}

model BusinessPlan {
  id            String   @id @default(cuid())
  userId        String   // stores sessionId or userId
  ideaId        String?
  customIdeaId  String?
  content       Json     // full plan content
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model TrendCache {
  id            String   @id
  keyword       String   @unique
  category      String
  description   String
  relatedIdeaIds Json    // array
  slug          String?  @unique
  report        Json?
  gtInterest    Float    @default(0)
  gtMomentum    Float    @default(0)
  platformScore Float    @default(0)
  aiScore       Float    @default(0)  // Claude web_search で算出した最新スコア
  aiMomentum    String   @default("") // Claude が判定したモメンタム（空=""未取得）
  aiUpdatedAt   DateTime?             // Claude スコア最終更新日時
  totalScore    Float    @default(0)
  momentum      String   @default("stable") // rising | stable | declining
  fetchedAt     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AiUsageLog {
  id         String   @id @default(cuid())
  identifier String   // sessionId or userId
  endpoint   String   // ai-search | ai-customize | ai-bizplan | ai-generate
  createdAt  DateTime @default(now())

  @@index([identifier, endpoint, createdAt])
}

// 生成ログ: どのシグナル×パターン → どんなアイデアが生まれたか
model GenerationLog {
  id             String   @id @default(cuid())
  sessionId      String
  theme          String                    // 生成テーマ
  hint           String?                   // 追加ヒント
  patterns       Json     @default("[]")  // 使用パターンID配列
  newsSourceUrls Json     @default("[]")  // 参照ニュースURL配列
  ideaId         String?                  // 保存されたアイデアID（nullable）
  userRating     Int?                     // ユーザー評価 1-5（後から記録）
  createdAt      DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([ideaId])
}

// アイデア品質の明示評価（リアクションとは別軸）
model IdeaRating {
  id         String   @id @default(cuid())
  ideaId     String
  sessionId  String
  isNovel    Boolean? // 新規性が高い
  isTimely   Boolean? // タイミングが良い
  isFeasible Boolean? // 実現しやすそう
  isExisting Boolean? // 既にある気がする
  createdAt  DateTime @default(now())

  idea       Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([ideaId, sessionId])
  @@index([ideaId])
}
