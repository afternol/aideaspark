# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Supabase ダッシュボード → Settings → Database → Connection string (URI) からコピー
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST].supabase.co:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# openssl rand -base64 32 で生成した強いランダム文字列を使用
AUTH_SECRET="[32文字以上のランダムシークレット]"
# 本番は実際のドメインに変更
AUTH_URL="https://aideaspark.jp"

# ─── Anthropic API ────────────────────────────────────────────────────────────
# https://console.anthropic.com/ から取得
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Google OAuth (任意) ───────────────────────────────────────────────────────
# Google Cloud Console → 認証情報 → OAuth 2.0 クライアントID から取得
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
